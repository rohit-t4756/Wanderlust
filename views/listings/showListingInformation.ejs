<% layout("/layouts/boilerplate") -%>
<body>
    <div class="row showBox mt-4">
        <div class="col-10"> 
            
            <h3><%= listing.title %></h3>
            <img 
                class="showListingImg mb-3" 
                src="<%= listing.image.url %>" 
                alt="<%= listing.image.filename %>">
            
            <div class="row align-items-start">
                <!-- LEFT COLUMN -->
                <div class="col-6">
                    <p id="description" style="opacity: 0.9;"><%= listing.description %></p>
                </div>
                
                <!-- RIGHT COLUMN -->
                <!-- This wrapper stacks the existing price card and your new card vertically -->
                <div class="col-6 d-flex flex-column align-items-center gap-3">
                    
                    <!-- Box 1:  Price & Location Card -->
                    <div class="card showPriceCard m-0">
                        <div class="card-body priceDabba">
                            <p class="card-text" style="font-weight: 600;">₹<%= listing.price %> for 1 night</p>
                            <p class="card-text location-text" style="font-weight: 300; font-size: 0.85rem;">
                                Located in: <%= listing.location %>,&nbsp;<%= listing.country %>
                            </p>
                        </div>
                    </div>

                    <!-- Box 2: Owner Card -->
                    <div class="card showPriceCard m-0">
                        <div class="card-body priceDabba">
                            <p class="card-text" style="font-weight: 600;">Owned by: <%= listing.owner.firstName %> <%= listing.owner.lastName %></p>
                        </div>
                    </div>

                </div>
            </div>
            <div class="buttons">
                <% if (requestBody.user && requestBody.user._id.equals(listing.owner._id)) { %>
                    <form action="/listings/<%=listing._id%>/edit" method="get" class="mb-2">
                        <button type="submit" class="btn btn-outline-dark">Edit this listing</button>
                    </form>
                    <form action="/listings/<%= listing._id %>?_method=DELETE" method="post" class="mb-2">
                        <button type="submit" class="btn btn-outline-dark">Delete this listing</button>
                    </form>
                <% } %>
                <br>
                <button 
                    class="btn btn-outline-dark mb-3" 
                    type="button" 
                    data-bs-toggle="collapse" 
                    data-bs-target="#reviewForm" 
                    aria-expanded="true" 
                    aria-controls="reviewForm"
                >
                    Write a review
                </button>
            </div>

            <div class="collapse accordion mb-4" id="reviewForm">
                <div class="card">
                    <div class="card-body">
                        <h4 style="margin-top: 2px; margin-left: 4px; padding: 4px"> Write a review for this listing</h4>
                        <hr style="margin: 0; padding: 0;">
                        <form action="/listings/<%= listing._id %>/reviews" method="POST">
                            <div id="ratingSection" style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 15px; margin-left: 6px;">
                                <label for="ratingInput">Rating</label>
                                <input 
                                    type="range"
                                    name="review[rating]" 
                                    id="ratingInput" 
                                    min=1 max=5
                                    style="width: 100%; max-width: 200px;"
                                >
                            </div>
                            <div id="commentSection" style="display: flex; align-items:flex-start; gap: 5px; margin-left: 6px;">
                                <label for="commentInput" style="white-space: nowrap; flex-shrink: 0;">
                                    Enter your comments (Please keep it civil):&nbsp;
                                </label>
                                <textarea 
                                    name="review[comment]"
                                    id="commentInput" 
                                    cols="20" rows="4"
                                    placeholder="How was your stay? Tell future guests about the space, location, and host."
                                    class="form-control"
                                    style="flex-grow: 1; box-sizing: border-box;"
                                ></textarea>
                            </div>
                            <button class="btn btn-outline-dark mb-3 mt-3" type="submit">Create review</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- All reviews -->
            <% if (listing.reviews && listing.reviews.length > 0) { %>
                <h4>All reviews</h4>
                <div class="row g-1 mt-1 mb-4"> 
                    <% for (let review of listing.reviews) { %>
                        <div class="col-md-6"> 
                            <div class="review-card card h-100">
                                <div class="card-body">
                                    <h5 class="card-title"><%= (review.username || "Jane Doe") %></h5>
                                    <div class="card-text">
                                        <%= "⭐".repeat(review.rating) %>
                                        <% if (!review.comment || review.comment.trim() === "") { %>
                                            <p class="text-muted">No comment.</p>
                                        <% } else { %>
                                            <p><%= review.comment %></p>
                                        <% } %>
                                    </div>
                                    <form 
                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>" 
                                        method="post"
                                        class="reviewDeleteForm" 
                                        data-review-id="<%= review._id %>"
                                    >
                                        <button class="btn btn-outline-dark" type="submit">Delete this review</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div> 
    </div>

    
    
    <!-- Accordion scroll into view -->
    <script>
        const accordions = document.querySelectorAll('.accordion .collapse');

        accordions.forEach(accordion => {
            accordion.addEventListener('shown.bs.collapse', function () {
                const header = this.previousElementSibling;
                
                header.scrollIntoView({ 
                    behavior: 'smooth', 
                    block: 'start' 
                });
            });
        });
    </script>

    <!-- Review Delete Button -->
    <script>
        // Attach listener to all review delete forms and read review id from data attribute
        const reviewDeleteForms = document.querySelectorAll('.reviewDeleteForm');
        reviewDeleteForms.forEach(form => {
            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                
                const listingId = "<%= listing._id %>";
                const reviewId = form.dataset.reviewId;
                
                try {
                    const response = await fetch(
                        `/listings/${listingId}/reviews/${reviewId}`, 
                        {
                            method: 'DELETE',
                            headers: { 'Content-Type': 'application/json' }
                        }
                    );
                    
                    if (response.ok) {
                        const result = await response.json();
                        console.log('Update successful:', result);
                        window.location.href = `/listings/${listingId}`;
                    } else {
                        alert('Failed to delete review.');
                    }
                } catch (error) {
                    console.error('Error sending review DELETE request:', error);
                    alert("Something went wrong while sending the review DELETE request.");
                }
            });
        });
    </script>
</body>