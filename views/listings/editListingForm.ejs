<% layout("/layouts/boilerplate") -%>
<body>
    <h2>Edit the listing for your property</h2>
    <form action="/listings/<%= params.id %>/edit" id="editForm">
        <div>
            <label for="titleInput">Enter the title for your property: </label>
            <input type="text" name="titleInput" id="titleInput" value="<%= listingData.title %>">
        </div>
        <div>
            <label for="descInput">Edit the description about your property: </label>
            <textarea name="descInput" id="descInput" cols="40" rows="2"><%=listingData.description%></textarea>
        </div>
        <div>
            <label for="priceInput">Edit the per night price for your property (INR): </label>
            <input type="number" id="priceInput" name="priceInput" min="0" step="0.01" placeholder="0.00">
        </div>
        <div>
            <label for="locationInput">Edit the rough location of the property</label>
            <input type="text" name="locationInput" id="locationInput">
        </div>
        <div>
            <label for="countryInput">Edit the country your property is in:</label>
            <select name="countryInput" id="countryInput">
                <option value="">Select a country...</option>
                <% countries.forEach(function(name) { %>
                    <option value="<%= name %>"><%= name %></option>
                <% }); %>
            </select>
        </div>
        <button  type="submit">Edit the listing</button>
    </form>
    <script>
        const editForm = document.getElementById("editForm");

        editForm.addEventListener("submit", async (event) => {
            event.preventDefault();

            const formData = new FormData(editForm);

            let content = {
                title: formData.get('titleInput'),
                description: formData.get('descInput'),
                price: formData.get('priceInput'),
                location: formData.get('locationInput'),
                country: formData.get('countryInput')
            }

            const listingId = "<%= params.id %>";
            try {
                const response = await fetch(`/listings/${listingId}/edit`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(content)
            });

            if (response.ok) {
                // Redirect or show success message
                const result = await response.json();
                console.log("Update successful:", result);
                window.location.href = '/listings/<%= params.id %>'; 
            } else {
                alert("Failed to update listing.");
            }
        } catch (error) {
            console.error("Error sending PATCH request:", error);
        }
    });
    </script>
</body>